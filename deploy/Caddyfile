# Replace PANEL_DOMAIN and API_DOMAIN with your actual domains.
# If running on a single domain, use the same value for both.

{$PANEL_DOMAIN} {
    reverse_proxy frontend:3000
}

{$API_DOMAIN} {
    # Main API
    reverse_proxy /api/* {$API_UPSTREAM:backend:2095}
    reverse_proxy /apiv2/* {$API_UPSTREAM:backend:2095}

    # Subscription service
    reverse_proxy /sub/* {$SUB_UPSTREAM:backend:2096}

    # Decoy: serve a plain static page on all other paths so the server
    # fingerprint looks like a web server rather than a proxy panel.
    handle {
        header Content-Type "text/html; charset=utf-8"
        respond `<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8"><title>Welcome</title>
<style>body{font-family:sans-serif;max-width:640px;margin:80px auto;color:#333}
h1{font-size:2rem}p{color:#666}</style></head>
<body><h1>Welcome</h1>
<p>This server is operating normally.</p></body>
</html>` 200
    }
}
